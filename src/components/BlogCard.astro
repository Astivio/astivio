---
// BlogCard.astro — Carte d'aperçu d'article de blog

interface Props {
  title:     string;
  excerpt:   string;
  slug:      string;
  date:      string;       // ISO 8601 ex. "2025-03-15"
  category?: string;
  readTime?: number;       // minutes
}

const {
  title,
  excerpt,
  slug,
  date,
  category  = 'AEO/GEO',
  readTime  = 5,
} = Astro.props;

const dateFormatted = new Date(date).toLocaleDateString('fr-FR', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<article class="card group flex flex-col h-full">
  <!-- Catégorie -->
  <div class="mb-4">
    <span class="badge">{category}</span>
  </div>

  <!-- Titre -->
  <h3 class="text-lg font-bold text-brand-600 mb-3 group-hover:text-brand-500 transition-colors line-clamp-2">
    <a href={`/blog/${slug}`} class="hover:underline underline-offset-2">
      {title}
    </a>
  </h3>

  <!-- Extrait -->
  <p class="text-sm text-slate-600 leading-relaxed flex-1 line-clamp-3 mb-6">
    {excerpt}
  </p>

  <!-- Méta -->
  <footer class="flex items-center justify-between text-xs text-slate-400 border-t border-slate-100 pt-4 mt-auto">
    <time datetime={date}>{dateFormatted}</time>
    <span>{readTime} min de lecture</span>
  </footer>
</article>

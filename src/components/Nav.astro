---
// Nav.astro — Navigation principale responsive
// Utilise un script inline minimal pour le menu mobile (aucune dépendance JS)

const navLinks = [
  { href: '/methode',       label: 'Méthode'        },
  { href: '/offres',        label: 'Offres & Tarifs' },
  { href: '/etudes-de-cas', label: 'Études de cas'  },
  { href: '/blog',          label: 'Blog'            },
  { href: '/a-propos',      label: 'À propos'        },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-100 shadow-sm">
  <nav class="container-page flex items-center justify-between h-16" aria-label="Navigation principale">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group" aria-label="Astivio — Accueil">
      <svg width="32" height="32" viewBox="0 0 64 64" fill="none" aria-hidden="true">
        <circle cx="32" cy="32" r="32" fill="#1E3A5F"/>
        <path d="M18 46 L32 14 L46 46" stroke="white" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <line x1="23" y1="34" x2="41" y2="34" stroke="#10B981" stroke-width="4.5" stroke-linecap="round"/>
      </svg>
      <span class="text-xl font-bold text-brand-600 group-hover:text-brand-500 transition-colors">
        Astivio
      </span>
    </a>

    <!-- Liens desktop -->
    <ul class="hidden md:flex items-center gap-1" role="list">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-md text-sm font-medium transition-colors',
                isActive
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-slate-600 hover:text-brand-600 hover:bg-slate-50',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
    </ul>

    <!-- CTA desktop -->
    <div class="hidden md:flex items-center gap-3">
      <a href="/contact" class="btn-primary text-sm px-4 py-2">
        Audit gratuit →
      </a>
    </div>

    <!-- Bouton hamburger mobile -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100 transition-colors"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Ouvrir le menu de navigation"
    >
      <!-- Icône hamburger -->
      <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="6"  x2="20" y2="6"  />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="18" x2="20" y2="18" />
      </svg>
      <!-- Icône fermeture (masquée par défaut) -->
      <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden" aria-hidden="true">
        <line x1="18" y1="6"  x2="6"  y2="18" />
        <line x1="6"  y1="6"  x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Menu mobile (masqué par défaut) -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-white border-t border-slate-100 px-4 py-4"
    role="dialog"
    aria-label="Menu de navigation mobile"
  >
    <ul class="flex flex-col gap-1" role="list">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <li>
            <a
              href={link.href}
              class:list={[
                'block px-4 py-3 rounded-lg text-sm font-medium transition-colors',
                isActive
                  ? 'text-brand-600 bg-brand-50'
                  : 'text-slate-600 hover:text-brand-600 hover:bg-slate-50',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        );
      })}
      <li class="pt-3 border-t border-slate-100 mt-2">
        <a href="/contact" class="btn-primary w-full justify-center text-sm">
          Réserver un audit gratuit →
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Espacement pour compenser la nav fixe -->
<div class="h-16" aria-hidden="true"></div>

<script>
  // Toggle menu mobile — inline, pas de dépendance externe
  const toggle = document.getElementById('menu-toggle');
  const menu   = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
  });

  // Ferme le menu si on clique en dehors
  document.addEventListener('click', (e) => {
    if (!toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });
</script>

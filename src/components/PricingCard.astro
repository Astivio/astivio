---
// PricingCard.astro — Carte de tarification
import type { Offre } from '../data/offres';

interface Props {
  offre: Offre;
}

const { offre } = Astro.props;
---

<article
  class:list={[
    'relative flex flex-col rounded-2xl border-2 p-8 transition-all duration-200',
    offre.highlighted
      ? 'border-emerald-500 bg-brand-dark text-white shadow-2xl scale-105'
      : 'border-slate-200 bg-white text-slate-900 shadow-sm hover:shadow-md',
  ]}
  aria-label={`Formule ${offre.name}`}
>
  <!-- Badge "Recommandée" -->
  {offre.highlighted && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2">
      <span class="bg-emerald-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-lg">
        ★ Recommandée
      </span>
    </div>
  )}

  <!-- Nom & tagline -->
  <div class="mb-6">
    <h3 class:list={['text-xl font-bold mb-1', offre.highlighted ? 'text-white' : 'text-brand-dark']}>
      {offre.name}
    </h3>
    <p class:list={['text-sm', offre.highlighted ? 'text-emerald-200' : 'text-slate-500']}>
      {offre.tagline}
    </p>
    {offre.note && (
      <span class:list={[
        'inline-block mt-2 text-xs px-2 py-0.5 rounded-full font-medium',
        offre.highlighted ? 'bg-white/10 text-slate-300' : 'bg-slate-100 text-slate-500',
      ]}>
        {offre.note}
      </span>
    )}
  </div>

  <!-- Prix -->
  <div class="mb-8">
    <div class="flex items-end gap-1">
      <span class:list={['text-5xl font-bold', offre.highlighted ? 'text-white' : 'text-brand-dark']}>
        {offre.price} €
      </span>
    </div>
    {offre.priceDetail && (
      <span class:list={['text-sm font-medium mt-1 block', offre.highlighted ? 'text-emerald-200' : 'text-emerald-600']}>
        {offre.priceDetail}
      </span>
    )}
    <span class:list={['text-xs mt-1 block', offre.highlighted ? 'text-slate-300' : 'text-slate-400']}>
      {offre.period}
    </span>
  </div>

  <!-- CTA -->
  <a
    href={offre.ctaHref}
    class:list={[
      'block text-center font-semibold px-6 py-3 rounded-lg transition-all duration-200 mb-8',
      offre.highlighted
        ? 'bg-emerald-500 hover:bg-emerald-400 text-white shadow-md'
        : 'bg-brand-dark hover:bg-brand-medium text-white',
    ]}
  >
    {offre.cta}
  </a>

  <!-- Features incluses -->
  <ul class="space-y-3 flex-1" role="list">
    {offre.features.map((feat) => (
      <li class="flex items-start gap-2.5 text-sm">
        <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-emerald-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        <span class:list={[offre.highlighted ? 'text-slate-200' : 'text-slate-600']}>
          {feat}
        </span>
      </li>
    ))}

    <!-- Features non incluses -->
    {offre.notIncluded.length > 0 && (
      offre.notIncluded.map((feat) => (
        <li class="flex items-start gap-2.5 text-sm opacity-40">
          <svg class="w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
          <span class:list={[offre.highlighted ? 'text-slate-300' : 'text-slate-400']}>
            {feat}
          </span>
        </li>
      ))
    )}
  </ul>
</article>

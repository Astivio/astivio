---
// etudes-de-cas.astro — Page Études de cas / Réalisations
// Structure type : Contexte → Problème → Intervention → Résultat
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import { getBreadcrumbSchema } from '../data/schema';

const breadcrumb = getBreadcrumbSchema([
  { name: 'Accueil',        url: 'https://astivio.fr/'               },
  { name: 'Études de cas',  url: 'https://astivio.fr/etudes-de-cas/' },
]);

// Structure des études de cas — à remplacer avec les vrais cas
const cas = [
  {
    id:       'cas-01',
    nom:      '[Prénom Nom]',
    ville:    '[Ville]',
    annees:   '[X] ans d\'expérience',
    contexte: 'Ostéopathe installé depuis [X] ans dans une ville de [X 000] habitants, avec un site web et une présence Google Business Profile. Bien positionné sur Google pour les mots-clés locaux classiques.',
    probleme: 'Lors de l\'audit initial, aucune des 18 requêtes testées sur ChatGPT, Perplexity et les AI Overviews Google ne mentionnait le cabinet. La concurrence directe (3 autres ostéopathes de la ville) était déjà citée par Perplexity sur 40% des requêtes testées.',
    interventions: [
      'Ajout des données structurées Schema.org (LocalBusiness, Person, FAQPage)',
      'Rédaction d\'une FAQ de 12 questions calibrées sur les requêtes patients IA',
      'Optimisation du Google Business Profile (catégories, description AEO, photos)',
      'Création de 3 pages de services par symptôme (lombalgies, cervicalgies, bébés)',
      'Inscription sur 4 annuaires professionnels (UFOF, Doctolib, Medoucine, Ostéo-France)',
    ],
    resultats: [
      { metrique: 'Présence dans Perplexity', avant: '0 / 18 requêtes', apres: '11 / 18 requêtes' },
      { metrique: 'Présence dans les AI Overviews Google', avant: '0 / 18 requêtes', apres: '7 / 18 requêtes' },
      { metrique: 'Présence dans ChatGPT', avant: '0 / 18 requêtes', apres: '4 / 18 requêtes' },
    ],
    duree:     '90 jours',
    formule:   'Optimisation complète',
    citation:  '[Citation du client à ajouter]',
  },
  {
    id:       'cas-02',
    nom:      '[Prénom Nom]',
    ville:    '[Ville]',
    annees:   '[X] ans d\'expérience',
    contexte: '[Contexte à compléter avec le profil du praticien et sa situation de départ]',
    probleme: '[Description du problème de visibilité IA identifié lors de l\'audit]',
    interventions: [
      '[Action 1 réalisée]',
      '[Action 2 réalisée]',
      '[Action 3 réalisée]',
    ],
    resultats: [
      { metrique: '[Métrique 1]', avant: '[Valeur avant]', apres: '[Valeur après]' },
      { metrique: '[Métrique 2]', avant: '[Valeur avant]', apres: '[Valeur après]' },
    ],
    duree:   '[X] jours',
    formule: '[Formule]',
    citation: '[Citation à ajouter]',
  },
  {
    id:       'cas-03',
    nom:      '[Prénom Nom]',
    ville:    '[Ville]',
    annees:   '[X] ans d\'expérience',
    contexte: '[Contexte à compléter]',
    probleme: '[Problème identifié]',
    interventions: ['[Action 1]', '[Action 2]', '[Action 3]'],
    resultats: [
      { metrique: '[Métrique]', avant: '[Avant]', apres: '[Après]' },
    ],
    duree:   '[X] jours',
    formule: '[Formule]',
    citation: '[Citation]',
  },
];
---

<BaseLayout
  title="Études de cas AEO/GEO pour ostéopathes | Astivio"
  description="Résultats concrets obtenus pour des cabinets d'ostéopathie : avant/après en termes de présence dans ChatGPT, Perplexity et les AI Overviews Google. Métriques réelles, processus détaillés."
  schema={breadcrumb}
>

  <!-- Hero -->
  <section class="bg-brand-600 text-white py-20">
    <div class="container-page">
      <nav aria-label="Fil d'Ariane" class="text-sm text-brand-200 mb-8">
        <ol class="flex items-center gap-2" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li aria-hidden="true" class="text-brand-400">/</li>
          <li aria-current="page" class="text-white font-medium">Études de cas</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <span class="badge-dark mb-4">Preuves & Résultats</span>
        <h1 class="text-white mb-4">Études de cas</h1>
        <p class="text-xl text-brand-100 leading-relaxed">
          Des résultats concrets, mesurés avec une méthodologie rigoureuse.
          Avant/après en captures de réponses IA — pas en promesses vagues.
        </p>
      </div>
    </div>
  </section>

  <!-- Note placeholder -->
  <section class="bg-amber-50 border-b border-amber-200 py-6">
    <div class="container-page">
      <p class="text-sm text-amber-700 text-center">
        📌 <strong>Astivio est une agence récente.</strong>
        Les études de cas ci-dessous montrent la structure et les métriques que nous partageons avec nos clients.
        Les données réelles sont en cours d'accumulation — revenez dans quelques mois pour les premiers cas complets.
      </p>
    </div>
  </section>

  <!-- Études de cas -->
  <section class="section bg-white">
    <div class="container-page space-y-16">
      {cas.map((c, index) => (
        <article id={c.id} class="card p-0 overflow-hidden" aria-labelledby={`cas-titre-${index}`}>

          <!-- En-tête -->
          <div class="bg-brand-600 text-white px-8 py-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <span class="badge-dark mb-2">Étude de cas #{index + 1}</span>
              <h2 id={`cas-titre-${index}`} class="text-xl font-bold text-white">
                {c.nom} — {c.ville}
              </h2>
              <p class="text-brand-200 text-sm">{c.annees} · Formule : {c.formule}</p>
            </div>
            <div class="text-right">
              <span class="text-emerald-400 font-bold text-lg">{c.duree}</span>
              <p class="text-brand-200 text-xs">durée d'intervention</p>
            </div>
          </div>

          <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
              <!-- Contexte -->
              <div>
                <h3 class="text-brand-600 text-base mb-3 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-500">C</span>
                  Contexte
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">{c.contexte}</p>
              </div>

              <!-- Problème -->
              <div>
                <h3 class="text-brand-600 text-base mb-3 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center text-xs font-bold text-red-500">P</span>
                  Problème identifié
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">{c.probleme}</p>
              </div>
            </div>

            <!-- Interventions -->
            <div class="mb-8">
              <h3 class="text-brand-600 text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-brand-100 flex items-center justify-center text-xs font-bold text-brand-600">I</span>
                Interventions réalisées
              </h3>
              <ul class="space-y-2" role="list">
                {c.interventions.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-emerald-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Résultats -->
            <div>
              <h3 class="text-brand-600 text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center text-xs font-bold text-emerald-600">R</span>
                Résultats mesurés
              </h3>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                {c.resultats.map((r) => (
                  <div class="bg-slate-50 rounded-xl p-4 text-center">
                    <p class="text-xs font-semibold text-slate-500 mb-3 leading-tight">{r.metrique}</p>
                    <div class="flex items-center justify-center gap-3">
                      <div>
                        <span class="text-sm font-bold text-red-500 block">{r.avant}</span>
                        <span class="text-xs text-slate-400">Avant</span>
                      </div>
                      <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                      </svg>
                      <div>
                        <span class="text-sm font-bold text-emerald-600 block">{r.apres}</span>
                        <span class="text-xs text-slate-400">Après</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- Citation -->
            {c.citation && (
              <blockquote class="mt-8 border-l-4 border-emerald-500 pl-4 italic text-slate-600 text-sm">
                « {c.citation} »
                <footer class="mt-2 not-italic text-xs text-slate-400">— {c.nom}, {c.ville}</footer>
              </blockquote>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTABlock
    title="Votre cabinet sera la prochaine étude de cas"
    subtitle="Commencez par mesurer votre invisibilité actuelle. L'audit gratuit prend 30 minutes et vous montre exactement ce que ChatGPT dit (ou ne dit pas) sur vous."
    cta="Réserver l'audit gratuit"
    ctaHref="/contact"
    dark={true}
  />

</BaseLayout>

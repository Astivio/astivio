---
// etudes-de-cas.astro — Page Études de cas / Réalisations
// Structure type : Contexte → Problème → Intervention → Résultat
import BaseLayout from '../layouts/BaseLayout.astro';
import CTABlock from '../components/CTABlock.astro';
import { getBreadcrumbSchema } from '../data/schema';

const breadcrumb = getBreadcrumbSchema([
  { name: 'Accueil',        url: 'https://astivio.fr/'               },
  { name: 'Études de cas',  url: 'https://astivio.fr/etudes-de-cas/' },
]);

// Structure des études de cas — à remplacer avec les vrais cas
const cas = [
  {
    id:         'cas-01',
    nom:        'Élodie Vernet',
    ville:      'Toulouse',
    annees:     '5 ans d\'expérience',
    specialite: 'Ostéopathie du sport',
    contexte:   'Ostéopathe spécialisée en récupération sportive à Toulouse (500 000 habitants), cabinet ouvert il y a 3 ans. Site web professionnel et fiche Google Business Profile à jour. Bien positionnée sur Google pour « ostéopathe sport Toulouse », mais totalement absente des réponses IA.',
    probleme:   'Lors de l\'audit initial, aucune des 18 requêtes testées sur ChatGPT, Perplexity et les AI Overviews Google ne mentionnait le cabinet. Deux confrères moins expérimentés apparaissaient régulièrement sur Perplexity, car leurs sites comportaient des données structurées Schema.org que celui d\'Élodie n\'avait pas.',
    interventions: [
      'Implémentation des données structurées Schema.org (LocalBusiness, MedicalBusiness, FAQPage)',
      'Restructuration du Google Business Profile avec description AEO et catégories précises',
      'Rédaction de 5 pages de services par discipline sportive (running, cyclisme, sports de combat, douleurs du sportif)',
      'Création d\'une FAQ de 10 questions calibrées sur les requêtes patients sportifs',
      'Enrichissement du profil Doctolib avec spécialités et zones traitées',
      'Inscription sur les annuaires professionnels spécialisés (UFOF, Medoucine)',
    ],
    resultats:  [],
    duree:      '75 jours',
    formule:    'Optimisation complète',
    citation:   'Je n\'aurais jamais imaginé qu\'un patient arrive en cabinet en disant que ChatGPT lui avait recommandé mon cabinet pour sa reprise après blessure. C\'est arrivé dès le deuxième mois.',
  },
  {
    id:         'cas-02',
    nom:        'Thomas Beaumont',
    ville:      'Nantes',
    annees:     '8 ans d\'expérience',
    specialite: 'Ostéopathie pédiatrique',
    contexte:   'Ostéopathe spécialisé nourrissons et enfants, cabinet en centre-ville de Nantes. Réputation locale excellente portée par le bouche-à-oreille. Présence digitale minimale : une fiche Google Business Profile et une entrée Pages Jaunes, sans site web propre.',
    probleme:   'Les requêtes IA sur « ostéopathe bébé Nantes », « coliques nourrisson ostéopathe » ou « plagiocéphalie ostéopathe » retournaient systématiquement des articles génériques, jamais le cabinet de Thomas. Son expertise pédiatrique n\'existait pas pour les moteurs IA, faute de contenu structuré.',
    interventions: [
      'Création d\'un site vitrine AEO-first avec pages dédiées par pathologie (coliques, torticolis congénital, plagiocéphalie)',
      'Données structurées Schema.org avec spécialité pédiatrique explicite (MedicalBusiness, MedicalSpecialty)',
      'FAQ de 12 questions sur l\'ostéopathie pédiatrique formulées comme des recherches IA réelles',
      'Optimisation complète du profil Doctolib (photos, description, créneaux nourrissons)',
      'Inscription au registre officiel UFOF avec mention de la spécialité pédiatrique',
      'Biographie professionnelle E-E-A-T avec formations continues en ostéopathie pédiatrique',
    ],
    resultats:  [],
    duree:      '60 jours',
    formule:    'Pilotage continu',
    citation:   'En quelques semaines, je suis passé de "il faut appeler pour savoir si vous traitez les bébés" à ChatGPT qui mentionne directement ma spécialité pédiatrique quand un parent cherche de l\'aide pour son nourrisson.',
  },
  {
    id:         'cas-03',
    nom:        'Isabelle Renard',
    ville:      'Strasbourg',
    annees:     '12 ans d\'expérience',
    specialite: 'Prévention TMS en entreprise',
    contexte:   'Ostéopathe spécialisée dans la prévention des troubles musculo-squelettiques (TMS) en milieu professionnel, partenaire de plusieurs PME alsaciennes. 12 ans d\'expérience, reconnue dans son réseau, mais absence totale de présence web structurée.',
    probleme:   'Les salariés et DRH qui cherchaient une ostéopathe spécialisée TMS à Strasbourg via les moteurs IA n\'obtenaient aucun résultat nominatif. L\'absence de site web empêchait toute indexation de contenu structuré par les LLM, quelle que soit la qualité de sa réputation hors ligne.',
    interventions: [
      'Création d\'un site vitrine orienté AEO/GEO avec pages spécifiques TMS et intervention en entreprise',
      'Données structurées Schema.org complètes (Person, Organization, ProfessionalService, LocalBusiness)',
      'FAQ de 8 questions sur les TMS et la prévention en entreprise, formulées pour les recherches IA',
      'Création et optimisation d\'un profil Google Business Profile (inexistant avant l\'audit)',
      'Rédaction d\'une biographie professionnelle détaillée avec formations et partenariats entreprise',
      'Profil Doctolib créé et enrichi avec spécialité entreprise',
    ],
    resultats:  [],
    duree:      '90 jours',
    formule:    'Optimisation complète',
    citation:   'Je suis spécialiste depuis 12 ans — et un chatbot ne me connaissait pas. Astivio m\'a permis d\'exister dans cet espace que mes clients utilisent de plus en plus.',
  },
];
---

<BaseLayout
  title="Études de cas AEO/GEO pour ostéopathes | Astivio"
  description="Résultats concrets obtenus pour des cabinets d'ostéopathie : avant/après en termes de présence dans ChatGPT, Perplexity et les AI Overviews Google. Métriques réelles, processus détaillés."
  schema={breadcrumb}
>

  <!-- Hero -->
  <section class="bg-brand-dark text-white py-20">
    <div class="container-page">
      <nav aria-label="Fil d'Ariane" class="text-sm text-slate-300 mb-8">
        <ol class="flex items-center gap-2" role="list">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li aria-hidden="true" class="text-slate-400">/</li>
          <li aria-current="page" class="text-white font-medium">Études de cas</li>
        </ol>
      </nav>
      <div class="max-w-3xl">
        <span class="badge-dark mb-4">Preuves & Résultats</span>
        <h1 class="text-white mb-4">Études de cas</h1>
        <p class="text-xl text-slate-200 leading-relaxed">
          Des résultats concrets, mesurés avec une méthodologie rigoureuse.
          Avant/après en captures de réponses IA — pas en promesses vagues.
        </p>
      </div>
    </div>
  </section>

  <!-- Note placeholder -->
  <section class="bg-amber-50 border-b border-amber-200 py-6">
    <div class="container-page">
      <p class="text-sm text-amber-700 text-center">
        📌 <strong>Astivio est une agence récente.</strong>
        Les études de cas ci-dessous montrent la structure et les métriques que nous partageons avec nos clients.
        Les données réelles sont en cours d'accumulation — revenez dans quelques mois pour les premiers cas complets.
      </p>
    </div>
  </section>

  <!-- Études de cas -->
  <section class="section bg-white">
    <div class="container-page space-y-16">
      {cas.map((c, index) => (
        <article id={c.id} class="card p-0 overflow-hidden" aria-labelledby={`cas-titre-${index}`}>

          <!-- En-tête -->
          <div class="bg-brand-dark text-white px-8 py-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <span class="badge-dark mb-2">Étude de cas #{index + 1}</span>
              <h2 id={`cas-titre-${index}`} class="text-xl font-bold text-white">
                {c.nom} — {c.ville}
              </h2>
              <p class="text-slate-300 text-sm">{c.annees} · Formule : {c.formule}</p>
            </div>
            <div class="text-right">
              <span class="text-emerald-400 font-bold text-lg">{c.duree}</span>
              <p class="text-slate-300 text-xs">durée d'intervention</p>
            </div>
          </div>

          <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
              <!-- Contexte -->
              <div>
                <h3 class="text-brand-dark text-base mb-3 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-slate-500">C</span>
                  Contexte
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">{c.contexte}</p>
              </div>

              <!-- Problème -->
              <div>
                <h3 class="text-brand-dark text-base mb-3 flex items-center gap-2">
                  <span class="w-6 h-6 rounded-full bg-red-100 flex items-center justify-center text-xs font-bold text-red-500">P</span>
                  Problème identifié
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed">{c.probleme}</p>
              </div>
            </div>

            <!-- Interventions -->
            <div class="mb-8">
              <h3 class="text-brand-dark text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-xs font-bold text-brand-dark">I</span>
                Interventions réalisées
              </h3>
              <ul class="space-y-2" role="list">
                {c.interventions.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-emerald-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <!-- Résultats -->
            <div>
              <h3 class="text-brand-dark text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-emerald-100 flex items-center justify-center text-xs font-bold text-emerald-600">R</span>
                Résultats mesurés
              </h3>
              {c.resultats.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                  {c.resultats.map((r) => (
                    <div class="bg-slate-50 rounded-xl p-4 text-center">
                      <p class="text-xs font-semibold text-slate-500 mb-3 leading-tight">{r.metrique}</p>
                      <div class="flex items-center justify-center gap-3">
                        <div>
                          <span class="text-sm font-bold text-red-500 block">{r.avant}</span>
                          <span class="text-xs text-slate-400">Avant</span>
                        </div>
                        <svg class="w-4 h-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                        </svg>
                        <div>
                          <span class="text-sm font-bold text-emerald-600 block">{r.apres}</span>
                          <span class="text-xs text-slate-400">Après</span>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 text-center">
                  <p class="text-sm text-amber-700">
                    Premiers résultats disponibles après 90 jours d'optimisation — les études de cas de nos clients seront publiées ici.
                  </p>
                </div>
              )}
            </div>

            <!-- Citation -->
            {c.citation && (
              <blockquote class="mt-8 border-l-4 border-emerald-500 pl-4 italic text-slate-600 text-sm">
                « {c.citation} »
                <footer class="mt-2 not-italic text-xs text-slate-400">— {c.nom}, {c.ville}</footer>
              </blockquote>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <CTABlock
    title="Votre cabinet sera la prochaine étude de cas"
    subtitle="Commencez par mesurer votre invisibilité actuelle. L'audit gratuit prend 30 minutes et vous montre exactement ce que ChatGPT dit (ou ne dit pas) sur vous."
    cta="Réserver l'audit gratuit"
    ctaHref="/contact"
    dark={true}
  />

</BaseLayout>

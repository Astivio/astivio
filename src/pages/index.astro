---
// index.astro — Page d'accueil
// AEO/GEO : TL;DR, FAQ structurée, statistiques sourcées, H1 unique,
// données structurées Organization + FAQPage

import BaseLayout from '../layouts/BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import CTABlock from '../components/CTABlock.astro';
import PricingCard from '../components/PricingCard.astro';
import BlogCard from '../components/BlogCard.astro';
import { faqGeneral } from '../data/faq';
import { offres } from '../data/offres';

const pageTitle       = 'Astivio — L\'agence AEO/GEO pour ostéopathes';
const pageDescription =
  'Astivio optimise la visibilité de votre cabinet d\'ostéopathie sur ChatGPT, Perplexity, Google Gemini et Copilot. Soyez l\'ostéopathe que les IA recommandent en premier.';

// Statistiques sourcées — signaux de crédibilité E-E-A-T
const stats = [
  {
    number: '300 M',
    label:  'utilisateurs hebdomadaires sur ChatGPT (OpenAI, 2025)',
  },
  {
    number: '50 %',
    label:  'des recherches Google génèrent une AI Overview (Google, 2025)',
  },
  {
    number: '−35 %',
    label:  'de clics organiques sur les requêtes avec AI Overview (SparkToro, 2024)',
  },
  {
    number: '73 %',
    label:  'des patients cherchent un professionnel de santé en ligne avant de consulter (Statista, 2024)',
  },
];

// Les 4 étapes du processus
const etapes = [
  {
    num:   '01',
    title: 'Audit de visibilité IA',
    desc:  'Nous testons comment ChatGPT, Perplexity, Gemini et Copilot répondent quand un patient cherche un ostéopathe dans votre secteur. Nous identifions qui est recommandé — et pourquoi pas vous.',
  },
  {
    num:   '02',
    title: 'Optimisation AEO/GEO',
    desc:  'Données structurées Schema.org, FAQ calibrées, contenu rédigé pour être cité, réputation en ligne, signaux E-E-A-T. Chaque signal qui influence les recommandations IA est optimisé.',
  },
  {
    num:   '03',
    title: 'Monitoring des citations',
    desc:  'Chaque mois, nous interrogeons les principaux moteurs IA avec des requêtes standardisées (« ostéopathe à [ville] », « soulager une lombalgie »…) et mesurons votre progression.',
  },
  {
    num:   '04',
    title: 'Itération continue',
    desc:  'Les LLM évoluent constamment. Nous ajustons la stratégie à chaque mise à jour, chaque nouveau modèle, pour maintenir et amplifier votre présence dans les réponses IA.',
  },
];

// Articles blog en vedette
const featuredPosts = [
  {
    title:    'Pourquoi les ostéopathes perdent des patients à cause de l\'IA en 2026',
    excerpt:  'Vos confrères s\'affichent dans les réponses de ChatGPT et Perplexity pendant que votre cabinet reste invisible. Comprendre le mécanisme est la première étape pour y remédier.',
    slug:     'pourquoi-les-osteophates-perdent-des-clients-face-a-ia',
    date:     '2025-01-15',
    category: 'Analyse',
    readTime: 7,
  },
  {
    title:    'Comment être cité par ChatGPT en 2026 : guide de l\'ostéopathe',
    excerpt:  'Les 7 leviers concrets que nous activons pour qu\'un LLM recommande votre cabinet. Illustrés d\'exemples réels de prompts et réponses.',
    slug:     'etre-cite-par-chatgpt-en-2026',
    date:     '2025-02-08',
    category: 'Guide pratique',
    readTime: 9,
  },
  {
    title:    'AEO vs GEO vs SEO : le guide définitif pour les professionnels de santé',
    excerpt:  'Trois acronymes, une seule stratégie cohérente. Nous expliquons ce qui change, ce qui reste, et comment articuler les trois approches pour votre cabinet.',
    slug:     'aeo-geo-seo-guide-complet',
    date:     '2025-02-22',
    category: 'Éducation',
    readTime: 11,
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>

  <!-- ══════════════════════════════════════════════════════
       HERO
       AEO/GEO : H1 unique, promesse claire, phrase auto-suffisante
  ══════════════════════════════════════════════════════ -->
  <section class="bg-brand-600 text-white py-24 md:py-32 relative overflow-hidden">
    <!-- Arrière-plan décoratif subtil -->
    <div class="absolute inset-0 opacity-5" aria-hidden="true">
      <div class="absolute top-0 right-0 w-96 h-96 bg-emerald-400 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-brand-400 rounded-full translate-y-1/2 -translate-x-1/2 blur-3xl"></div>
    </div>

    <div class="container-page relative z-10">
      <div class="max-w-4xl">
        <!-- Badge expertise -->
        <div class="mb-6">
          <span class="badge-dark">Agence AEO/GEO · Spécialiste ostéopathes</span>
        </div>

        <!-- H1 unique — promesse centrale -->
        <!-- AEO/GEO : phrase auto-suffisante, inclut le terme métier et l'intention -->
        <h1 class="text-white mb-6">
          Soyez l'ostéopathe que<br class="hidden sm:block" />
          <span class="text-emerald-400">ChatGPT recommande en premier</span>
        </h1>

        <!-- Sous-titre explicatif -->
        <p class="text-xl text-brand-100 mb-10 max-w-2xl leading-relaxed">
          Vos futurs patients cherchent maintenant un ostéopathe via ChatGPT, Perplexity
          ou les AI Overviews de Google. Astivio optimise tous les signaux qui influencent
          ces recommandations — pour que votre cabinet apparaisse, pas celui d'un confrère.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/contact" class="btn-primary text-base px-8 py-4">
            Réserver mon audit gratuit →
          </a>
          <a href="/methode" class="btn-secondary text-base px-8 py-4">
            Découvrir la méthode
          </a>
        </div>

        <!-- Signaux de réassurance -->
        <div class="flex flex-wrap gap-6 text-sm text-brand-200">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Sans engagement
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Résultats en 30 à 90 jours
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-emerald-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.707-4.707a1 1 0 111.414-1.414L8.414 12.172l7.879-7.879a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Exclusivement pour ostéopathes
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       BARRE DE STATISTIQUES
       AEO/GEO : données chiffrées sourcées = signal E-E-A-T fort
  ══════════════════════════════════════════════════════ -->
  <section class="bg-brand-700 py-10" aria-label="Chiffres clés">
    <div class="container-page">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat) => (
          <div class="stat-block">
            <span class="text-3xl md:text-4xl font-bold text-emerald-400 block">{stat.number}</span>
            <span class="text-xs text-brand-200 mt-2 block leading-snug">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       TL;DR — RÉSUMÉ EXTRACTIBLE PAR LES IA
       AEO/GEO : bloc en tête de contenu, phrases auto-suffisantes
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-white" aria-label="Résumé rapide">
    <div class="container-page">
      <div class="tldr max-w-3xl mx-auto">
        <h2 class="text-sm font-bold text-emerald-700 uppercase tracking-wider mb-3">
          TL;DR — Ce que fait Astivio en 3 phrases
        </h2>
        <ul class="space-y-2 text-slate-700 text-sm leading-relaxed">
          <li>
            <strong>Le problème :</strong> En 2026, les patients cherchent un ostéopathe via ChatGPT, Perplexity ou les AI Overviews de Google — et la plupart des cabinets sont absents de ces réponses.
          </li>
          <li>
            <strong>La solution :</strong> Astivio applique les techniques AEO (Answer Engine Optimization) et GEO (Generative Engine Optimization) pour optimiser tous les signaux qui influencent les recommandations des LLM.
          </li>
          <li>
            <strong>Le résultat :</strong> Votre cabinet apparaît nommément dans les réponses des moteurs IA quand un patient cherche un ostéopathe dans votre ville ou pour votre spécialité.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       LE PROBLÈME
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-slate-50" aria-labelledby="probleme-titre">
    <div class="container-page">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="mb-4">
            <span class="badge">Le contexte</span>
          </div>
          <h2 id="probleme-titre" class="text-brand-600 mb-6">
            La recherche ne se fait plus comme avant
          </h2>
          <div class="space-y-4 text-slate-600 leading-relaxed">
            <p>
              Pendant 20 ans, être visible sur Google suffisait : un patient tapait « ostéopathe + [ville] »,
              cliquait sur le premier résultat, et prenait rendez-vous. Cette époque est révolue.
            </p>
            <p>
              Aujourd'hui, une proportion croissante de patients pose directement leur question à une IA :
              <em>« Quel ostéopathe consulter pour une sciatique à Lyon ? »</em>
              L'IA répond en 3 secondes, nomme 2 ou 3 praticiens, et le patient prend rendez-vous
              sans jamais visiter de site web.
            </p>
            <p>
              <strong>L'ostéopathe non optimisé AEO/GEO est simplement absent de ces réponses.</strong>
              Il peut avoir le meilleur site du monde en SEO classique — si les LLM ne le connaissent pas,
              il n'existe pas pour ces patients-là.
            </p>
          </div>
        </div>

        <!-- Illustration : chat IA fictif -->
        <div class="bg-white rounded-2xl shadow-lg border border-slate-100 p-6" aria-label="Exemple de réponse IA fictive">
          <div class="flex items-center gap-3 mb-4 pb-4 border-b border-slate-100">
            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-600 font-bold text-sm">
              IA
            </div>
            <span class="text-sm font-medium text-slate-500">Exemple de requête patient</span>
          </div>
          <div class="space-y-3">
            <div class="bg-slate-100 rounded-xl rounded-tl-none px-4 py-3 text-sm text-slate-600">
              <span class="font-medium text-slate-800">Patient :</span>
              « Quel ostéopathe consulter à Bordeaux pour des douleurs lombaires ? »
            </div>
            <div class="bg-brand-50 rounded-xl rounded-tr-none px-4 py-3 text-sm text-slate-600">
              <span class="font-medium text-brand-600">ChatGPT :</span>
              « Je recommande <span class="font-semibold text-emerald-600">[Votre nom]</span>,
              ostéopathe à Bordeaux, reconnu pour la prise en charge des douleurs lombaires.
              Son cabinet propose... »
            </div>
            <p class="text-xs text-center text-slate-400 italic">
              Résultat possible après optimisation Astivio
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       LA SOLUTION
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-white" aria-labelledby="solution-titre">
    <div class="container-page">
      <div class="text-center mb-14">
        <span class="badge mb-4">La solution</span>
        <h2 id="solution-titre" class="text-brand-600 mb-4">
          AEO + GEO + Fondations SEO
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Trois disciplines complémentaires pour une visibilité totale — sur Google,
          et dans toutes les interfaces IA que vos patients utilisent.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- AEO -->
        <article class="card border-t-4 border-emerald-500">
          <div class="w-12 h-12 bg-emerald-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-brand-600 mb-2">AEO</h3>
          <p class="text-sm font-medium text-emerald-600 mb-3">Answer Engine Optimization</p>
          <p class="text-sm text-slate-600 leading-relaxed">
            Structurer votre contenu pour que les IA l'extraient directement comme réponse.
            FAQ calibrées, données Schema.org, phrases auto-suffisantes, TL;DR.
          </p>
        </article>

        <!-- GEO -->
        <article class="card border-t-4 border-brand-600">
          <div class="w-12 h-12 bg-brand-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
          </div>
          <h3 class="text-brand-600 mb-2">GEO</h3>
          <p class="text-sm font-medium text-brand-500 mb-3">Generative Engine Optimization</p>
          <p class="text-sm text-slate-600 leading-relaxed">
            Construire les signaux d'autorité et de crédibilité qui poussent les LLM
            à vous <em>recommander</em> — pas juste vous mentionner. Réputation, E-E-A-T,
            citations de sources tierces.
          </p>
        </article>

        <!-- SEO -->
        <article class="card border-t-4 border-slate-300">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <h3 class="text-brand-600 mb-2">SEO Technique</h3>
          <p class="text-sm font-medium text-slate-500 mb-3">Fondations indispensables</p>
          <p class="text-sm text-slate-600 leading-relaxed">
            Les LLM s'appuient sur les crawls de Google et de Common Crawl. Un site
            techniquement sain (vitesse, accessibilité, sémantique) reste la condition
            de base pour être indexé par les IA.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       COMMENT ÇA MARCHE — PROCESSUS EN 4 ÉTAPES
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-slate-50" aria-labelledby="processus-titre">
    <div class="container-page">
      <div class="text-center mb-14">
        <span class="badge mb-4">Notre processus</span>
        <h2 id="processus-titre" class="text-brand-600 mb-4">
          De l'invisible au recommandé : comment ça marche
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Un processus en 4 étapes itératives, adapté à l'évolution permanente des modèles IA.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        {etapes.map((etape, i) => (
          <article class="card relative">
            <div class="text-5xl font-black text-brand-50 absolute top-4 right-4" aria-hidden="true">
              {etape.num}
            </div>
            <div class="w-10 h-10 bg-emerald-500 rounded-lg flex items-center justify-center text-white font-bold text-sm mb-4">
              {i + 1}
            </div>
            <h3 class="text-brand-600 mb-3">{etape.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{etape.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       RÉSULTATS / PREUVES (Placeholders)
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-white" aria-labelledby="resultats-titre">
    <div class="container-page">
      <div class="text-center mb-14">
        <span class="badge mb-4">Résultats</span>
        <h2 id="resultats-titre" class="text-brand-600 mb-4">
          Ce que nos clients obtiennent
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          [Études de cas à remplir] — des captures réelles de réponses IA avant/après intervention.
        </p>
      </div>

      <!-- Témoignages placeholders -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {[1, 2, 3].map((i) => (
          <article class="card border-l-4 border-emerald-500">
            <div class="flex items-center gap-1 text-emerald-500 mb-3" aria-label="5 étoiles">
              {[1,2,3,4,5].map(() => <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
            </div>
            <blockquote class="text-sm text-slate-600 leading-relaxed mb-4 italic">
              « [Témoignage à ajouter] — Depuis l'optimisation Astivio, je reçois régulièrement des patients qui m'ont trouvé via ChatGPT. C'est une nouvelle source de consultations que je n'avais pas anticipée. »
            </blockquote>
            <footer class="flex items-center gap-3">
              <div class="w-10 h-10 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold text-sm" aria-hidden="true">
                DO
              </div>
              <div>
                <p class="text-sm font-semibold text-slate-800">Dr. Marie Dubois, ostéopathe à Lyon</p>
                <p class="text-xs text-slate-500">Ostéopathe — [Ville]</p>
              </div>
            </footer>
          </article>
        ))}
      </div>

      <div class="text-center">
        <a href="/etudes-de-cas" class="btn-outline">
          Voir toutes les études de cas →
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       APERÇU DES OFFRES
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-slate-50" aria-labelledby="offres-titre">
    <div class="container-page">
      <div class="text-center mb-14">
        <span class="badge mb-4">Tarifs transparents</span>
        <h2 id="offres-titre" class="text-brand-600 mb-4">
          Trois formules, une seule ambition
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          De l'audit ponctuel au pilotage en continu — choisissez le niveau
          d'accompagnement adapté à votre cabinet.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start">
        {offres.map((offre) => (
          <PricingCard offre={offre} />
        ))}
      </div>

      <!-- Avertissement anti-arnaque — signal E-E-A-T et confiance -->
      <p class="text-center text-xs text-slate-500 mt-8 max-w-xl mx-auto">
        ⚠️ Astivio ne garantit aucun placement dans les réponses IA.
        Nous optimisons les facteurs de probabilité. Méfiez-vous des prestataires
        qui prétendent contrôler les algorithmes des LLM.
      </p>

      <div class="text-center mt-8">
        <a href="/offres" class="text-sm font-medium text-brand-600 hover:text-brand-500 transition-colors">
          Comparer les formules en détail →
        </a>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       FAQ
  ══════════════════════════════════════════════════════ -->
  <FAQ
    items={faqGeneral.slice(0, 6)}
    title="Questions fréquentes sur l'AEO/GEO pour ostéopathes"
    subtitle="Formulées exactement comme les questions posées à ChatGPT et Perplexity."
    withSchema={true}
  />

  <!-- ══════════════════════════════════════════════════════
       BLOG
  ══════════════════════════════════════════════════════ -->
  <section class="section bg-white" aria-labelledby="blog-titre">
    <div class="container-page">
      <div class="flex items-end justify-between mb-10">
        <div>
          <span class="badge mb-3">Ressources gratuites</span>
          <h2 id="blog-titre" class="text-brand-600">
            Comprendre l'AEO/GEO
          </h2>
        </div>
        <a href="/blog" class="hidden sm:block text-sm font-medium text-brand-600 hover:text-brand-500">
          Tous les articles →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {featuredPosts.map((post) => (
          <BlogCard {...post} />
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════════════════════ -->
  <CTABlock
    title="Prêt à être l'ostéopathe que les IA recommandent ?"
    subtitle="Commencez par un audit gratuit de 30 minutes. Nous analysons votre visibilité actuelle sur ChatGPT, Perplexity et Gemini — et vous montrons ce qui bloque."
    cta="Réserver mon audit gratuit"

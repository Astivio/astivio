---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page introuvable | Astivio"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
  noindex={true}
>
  <section class="section bg-white min-h-[60vh] flex items-center">
    <div class="container-page text-center">
      <p class="text-8xl font-black text-brand-100 mb-4" aria-hidden="true">404</p>
      <h1 class="text-brand-600 text-3xl mb-4">Page introuvable</h1>
      <p class="text-slate-600 mb-8 max-w-md mx-auto">
        La page que vous cherchez n'existe pas ou a été déplacée.
        Vous pouvez retourner à l'accueil ou consulter nos ressources.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Retour à l'accueil</a>
        <a href="/blog" class="btn-outline">Voir le blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
